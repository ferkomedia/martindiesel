---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
let d: any = {};
try { d = JSON.parse(fs.readFileSync('src/content/pages/products-settings.json', 'utf-8')); } catch {}
const products = await getCollection('services');
const sorted = products.sort((a, b) => (a.data.order||0) - (b.data.order||0));
---
<BaseLayout title="Produkty | Martin Diesel">
  <div class="page-hero"><div class="page-hero-inner">
    <span class="hero-label">{d.heroLabel||'Katalóg produktov'}</span>
    <h1>{d.heroTitle||'Náhradné diely pre motory'} <span class="hero-accent">{d.heroAccent||'URII a URIV'}</span></h1>
    {d.heroDesc && <p class="hero-desc">{d.heroDesc}</p>}
  </div></div>
  <div class="pg">{sorted.map((p) => {
    const slug = p.id.replace(/\.mdoc$/,'').replace(/\.md$/,'');
    return (
    <a href={`/produkty/${slug}`} class="pc"><div class="pi">{p.data.featuredImage?(<img src={p.data.featuredImage} alt={p.data.title}/>):(<div class="pp"></div>)}</div>
    <div class="pb"><h2>{p.data.title}</h2>{p.data.shortDescription&&<p>{p.data.shortDescription}</p>}<span class="pl">{d.cardLinkText||'Technické detaily'} →</span></div></a>
  )})}</div>
  {sorted.length===0&&<p style="color:var(--c-muted)">Žiadne produkty.</p>}
</BaseLayout>
<style>
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;padding-bottom:4rem}
.pc{background:#fff;border:1px solid var(--c-border);border-radius:var(--r);overflow:hidden;text-decoration:none;color:inherit;transition:all .25s}
.pc:hover{border-color:var(--c-primary);box-shadow:var(--shadow-md);transform:translateY(-2px)}
.pi{height:200px;overflow:hidden;background:var(--c-bg-alt)}.pi img{width:100%;height:100%;object-fit:cover}
.pp{width:100%;height:100%;background:#f1f5f9}.pb{padding:1.25rem}.pc h2{font-size:1.05rem;margin-bottom:.3rem}
.pc p{font-size:.82rem;color:var(--c-text-2);display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.pl{font-family:var(--font-display);font-weight:600;font-size:.8rem;color:var(--c-primary);margin-top:.85rem;display:inline-block}
</style>
