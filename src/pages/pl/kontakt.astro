---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
const siteData = JSON.parse(fs.readFileSync('src/content/settings/site.json', 'utf-8'));
let d: any = {};
try { d = JSON.parse(fs.readFileSync('src/content/pages/contact-pl.json', 'utf-8')); } catch {}
const phone = siteData.phone || '';
const email = siteData.contactEmail || '';
const subjects = d.formSubjects || ['Zapytanie o część','Konsultacja techniczna','Oferta cenowa','Inne'];
---
<BaseLayout title="Kontakt | Martin Diesel">
  <div class="page-hero"><div class="page-hero-inner">
    <span class="hero-label">Kontakt</span>
    <h1>{d.heroTitle||'Skontaktuj się z naszym'} <span class="hero-accent">{d.heroAccent||'zespołem'}</span></h1>
    {d.heroDesc && <p class="hero-desc">{d.heroDesc}</p>}
  </div></div>
  <div class="ir">
    {phone && <a href={`tel:${phone.replace(/\s/g,'')}`} class="ic ih"><h3>Telefon</h3><span class="iv">{phone}</span><span class="is">{siteData.openingHours||'Pn–Pt: 7:00 – 15:30'}</span></a>}
    {email && <a href={`mailto:${email}`} class="ic"><h3>Email</h3><span class="iv">{email}</span><span class="is">Odpowiemy w ciągu 24h</span></a>}
    <div class="ic"><h3>Adres</h3><span class="iv">{siteData.address||'Martin'}</span><span class="is">Słowacja</span></div>
  </div>
  <div class="cm">
    <form id="cf" class="cform">
      <h2>Napisz do nas</h2>
      <div class="fr"><div class="fg"><label for="name">Imię / Firma</label><input type="text" id="name" name="name" placeholder="Jan Kowalski" required/></div><div class="fg"><label for="email">Email</label><input type="email" id="email" name="email" placeholder="jan@firma.pl" required/></div></div>
      <div class="fr"><div class="fg"><label for="phone">Telefon</label><input type="tel" id="phone" name="phone" placeholder="+48 XXX XXX XXX"/></div><div class="fg"><label for="subject">Temat</label><select id="subject" name="subject" required><option value="" disabled selected>Wybierz...</option>{subjects.map((s:string)=>(<option value={s}>{s}</option>))}</select></div></div>
      <div class="fg"><label for="partnum">Numer katalogowy (opcjonalnie)</label><input type="text" id="partnum" name="partnum" placeholder="np. 89002599"/></div>
      <div class="fg"><label for="message">Wiadomość</label><textarea id="message" name="message" rows="5" placeholder="Opisz zapotrzebowanie..."></textarea></div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:.8rem">Wyślij zapytanie →</button>
      <div id="fs" class="fs"></div>
    </form>
    <div class="cmap"><h2>Gdzie nas znajdziesz</h2><p>{d.mapAddress||'Langsfeldova 1, 036 01 Martin, Słowacja'}</p>
      <div class="mw"><iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2615.8!2d18.9217!3d49.0658!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47154b8a0e3e1c1d%3A0x0!2zTGFuZ3NmZWxkb3ZhIDEsIE1hcnRpbg!5e0!3m2!1ssk!2ssk!4v1" width="100%" height="100%" style="border:0" allowfullscreen="" loading="lazy"></iframe></div>
    </div>
  </div>
</BaseLayout>
<script>
  const f=document.getElementById('cf') as HTMLFormElement,s=document.getElementById('fs') as HTMLDivElement;
  f.addEventListener('submit',async(e)=>{e.preventDefault();s.textContent='Wysyłam...';s.className='fs sending';
    const d=Object.fromEntries(new FormData(f));
    try{const r=await fetch('/api/contact',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});
      if(r.ok){s.textContent='Zapytanie wysłane!';s.className='fs ok';f.reset();typeof gtag!=='undefined'&&gtag('event','generate_lead',{currency:'EUR',value:50})}else throw 0}catch{s.textContent='Błąd. Zadzwoń do nas.';s.className='fs err'}});
</script>
<style>
.ir{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:3rem}
.ic{text-align:center;padding:2rem 1.5rem;border-radius:var(--r);background:var(--c-bg-alt);border:1px solid var(--c-border);text-decoration:none;color:inherit;transition:border-color .2s,box-shadow .2s}
.ic:hover{border-color:var(--c-primary);box-shadow:var(--shadow-md)}.ih{background:var(--c-primary-bg);border-color:var(--c-primary-100)}
.ic h3{font-size:.8rem;color:var(--c-muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:.25rem}
.iv{display:block;font-family:var(--font-display);font-weight:700;font-size:1.05rem;color:var(--c-primary);margin-bottom:.15rem}
.is{font-size:.78rem;color:var(--c-muted)}@media(max-width:640px){.ir{grid-template-columns:1fr}}
.cm{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start;padding-bottom:3rem}
.cform{display:flex;flex-direction:column;gap:1rem}.cform h2{font-size:1.25rem;margin-bottom:.25rem}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.fg{display:flex;flex-direction:column;gap:.3rem}
label{font-family:var(--font-display);font-weight:600;font-size:.8rem}
input,textarea,select{padding:.7rem .9rem;border:1.5px solid var(--c-border);border-radius:var(--r-sm);font-size:.9rem;font-family:var(--font-body);background:#fff;transition:border-color .2s,box-shadow .2s}
select{appearance:none}input::placeholder,textarea::placeholder{color:var(--c-muted)}
input:focus,textarea:focus,select:focus{outline:none;border-color:var(--c-primary);box-shadow:0 0 0 3px var(--c-primary-bg)}
textarea{resize:vertical;min-height:120px}
.fs{text-align:center;font-size:.85rem;font-weight:500;padding:.5rem;border-radius:var(--r-sm)}.fs.ok{color:#16a34a;background:#f0fdf4}.fs.err{color:#dc2626;background:#fef2f2}
.cmap{display:flex;flex-direction:column;gap:.5rem}.cmap h2{font-size:1.25rem}.cmap p{font-size:.88rem;color:var(--c-text-2);margin-bottom:.5rem}
.mw{border-radius:var(--r);overflow:hidden;border:1px solid var(--c-border);height:400px}.mw iframe{display:block;width:100%;height:100%}
@media(max-width:768px){.cm{grid-template-columns:1fr;gap:2rem}.fr{grid-template-columns:1fr}.mw{height:280px}}
</style>
