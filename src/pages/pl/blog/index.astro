---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = await getCollection('posts-pl', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---
<BaseLayout title="Blog | Martin Diesel">
  <div class="page-hero"><div class="page-hero-inner"><span class="hero-label">Blog</span><h1>Artykuły <span class="hero-accent">techniczne</span></h1><p class="hero-desc">Szczegółowe informacje o produkcji, funkcjach i konserwacji komponentów silnikowych.</p></div></div>
  <div class="pg">{sorted.map((p) => {
    const slug = p.id.replace(/\.mdoc$/, '').replace(/\.md$/, '');
    return (
    <a href={`/pl/blog/${slug}`} class="pc"><time>{new Date(p.data.publishDate).toLocaleDateString('pl-PL')}</time><h2>{p.data.title}</h2>{p.data.excerpt&&<p>{p.data.excerpt}</p>}<span class="plink">Czytaj artykuł →</span></a>
  )})}</div>
  {sorted.length===0&&<p style="color:var(--c-muted)">Brak artykułów.</p>}
</BaseLayout>
<style>
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1.25rem;padding-bottom:4rem}
.pc{display:flex;flex-direction:column;background:#fff;border:1px solid var(--c-border);border-radius:var(--r);padding:1.5rem;text-decoration:none;color:inherit;transition:all .25s}
.pc:hover{border-color:var(--c-primary);box-shadow:var(--shadow-md);transform:translateY(-2px)}
.pc time{font-size:.75rem;color:var(--c-muted)}.pc h2{font-size:1.05rem;margin:.4rem 0 .3rem;line-height:1.3}
.pc p{font-size:.82rem;color:var(--c-text-2);display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;flex:1}
.plink{font-family:var(--font-display);font-weight:600;font-size:.8rem;color:var(--c-primary);margin-top:1rem}
</style>
