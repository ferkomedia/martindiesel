---
import fs from 'node:fs';
const siteData = JSON.parse(fs.readFileSync('src/content/settings/site.json', 'utf-8'));
const navData = JSON.parse(fs.readFileSync('src/content/settings/navigation.json', 'utf-8'));
let footerData: any = {};
try { footerData = JSON.parse(fs.readFileSync('src/content/settings/footer.json', 'utf-8')); } catch {}

interface Props { title: string; description?: string; }
const { title, description = siteData.siteDescription || 'Martin Diesel' } = Astro.props;
const currentPath = Astro.url.pathname;
const isPL = currentPath.startsWith('/pl');
const siteName = siteData.siteName || 'Martin Diesel';
const phone = siteData.phone || '+421 43 4224 130';
const email = siteData.contactEmail || '';
const address = siteData.address || 'Martin, Slovensko';
const hours = siteData.openingHours || 'Po–Pi: 7:00 – 15:30';
const logo = siteData.logo || '/images/logo-martin-diesel.png';
const skNavItems = navData.items || [];
const plNavLabels: Record<string,string> = { 'Domov':'Strona główna', 'Produkty':'Produkty', 'Blog':'Blog', 'O nás':'O nas', 'Kontakt':'Kontakt' };
const navItems = isPL ? skNavItems.map((item: any) => ({ ...item, label: plNavLabels[item.label] || item.label, href: item.href === '/' ? '/pl/' : `/pl${item.href}` })) : skNavItems;
const productLinks = footerData.productLinks || [];
const createdBy = footerData.createdBy || 'FerkoMedia';
const createdByUrl = footerData.createdByUrl || 'https://ferkomedia.sk';
const fProductsTitle = footerData.sectionProductsTitle || 'Produkty';
const fPagesTitle = footerData.sectionPagesTitle || 'Stránky';
const fContactTitle = footerData.sectionContactTitle || 'Kontakt';
const skPath = isPL ? (currentPath.replace(/^\/pl/, '') || '/') : currentPath;
const plPath = isPL ? currentPath : '/pl' + currentPath;
---
<!DOCTYPE html>
<html lang={isPL ? 'pl' : 'sk'}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={`https://martindiesel.sk${currentPath}`} />
  <link rel="alternate" hreflang="sk" href={`https://martindiesel.sk${skPath}`} />
  <link rel="alternate" hreflang="pl" href={`https://martindiesel.sk${plPath}`} />
  <link rel="alternate" hreflang="x-default" href={`https://martindiesel.sk${skPath}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://martindiesel.sk${currentPath}`} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content={isPL ? 'pl_PL' : 'sk_SK'} />
  <meta property="og:site_name" content={siteName} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0f172a" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Martin Diesel" />
  <link rel="apple-touch-icon" href="/icons/icon-192.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href={isPL ? '/pl/' : '/'} class="logo">
      {logo && <img src={logo} alt={siteName} class="logo-img" />}
      <span class="logo-text">{siteName}</span>
    </a>
    <nav class="nav-desktop">
      {navItems.map((item: any, i: number) => (
          <a href={item.href} class:list={[i === navItems.length - 1 ? 'nav-cta' : '', { active: item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href) }]}>{item.label}</a>
      ))}
    </nav>
    <div class="lang-switch">
      <a href={currentPath.startsWith('/pl') ? currentPath.replace('/pl', '') || '/' : currentPath} class:list={[{ active: !currentPath.startsWith('/pl') }]}>SK</a>
      <a href={currentPath.startsWith('/pl') ? currentPath : `/pl${currentPath}`} class:list={[{ active: currentPath.startsWith('/pl') }]}>PL</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menu"><span></span><span></span><span></span></button>
  </div>
</header>
<div class="overlay" id="overlay"></div>
<nav class="offcanvas" id="offcanvas">
  <div class="oc-header">
    <a href={isPL ? '/pl/' : '/'} class="logo">{logo && <img src={logo} alt={siteName} class="logo-img" />}<span class="logo-text">{siteName}</span></a>
    <button class="oc-close" id="oc-close" aria-label="Zatvoriť"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg></button>
  </div>
  <div class="oc-links">{navItems.map((item: any) => (<a href={item.href} class:list={[{ active: item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href) }]}>{item.label}</a>))}</div>
  <div class="oc-footer">
    <a href={`tel:${phone.replace(/\s/g, '')}`} class="oc-phone"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>{phone}</a>
    <p class="oc-hours">{hours}</p>
  </div>
</nav>
<main><slot /></main>
<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={isPL ? '/pl/' : '/'} class="logo">{logo && <img src={logo} alt={siteName} class="logo-img logo-img-light" />}<span class="logo-text">{siteName}</span></a>
      <p class="footer-tagline">{siteData.siteDescription}</p>
    </div>
    {productLinks.length > 0 && (
        <div class="footer-links"><h4>{fProductsTitle}</h4>{productLinks.map((l: any) => (<a href={isPL ? `/pl${l.href}` : l.href}>{l.label}</a>))}</div>
    )}
    <div class="footer-links"><h4>{isPL ? 'Strony' : fPagesTitle}</h4>{navItems.map((item: any) => (<a href={item.href}>{item.label}</a>))}</div>
    <div class="footer-contact">
      <h4>{fContactTitle}</h4>
      <div class="fc-item"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg><a href={`tel:${phone.replace(/\s/g, '')}`}>{phone}</a></div>
      {email && <div class="fc-item"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg><a href={`mailto:${email}`}>{email}</a></div>}
      <div class="fc-item"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg><span>{address}</span></div>
      <p class="fc-hours">{hours}</p>
    </div>
  </div>
  <div class="footer-bottom"><p>&copy; {new Date().getFullYear()} {footerData.copyrightText || siteName} | Vytvoril <a href={createdByUrl} target="_blank" rel="noopener">{createdBy}</a></p></div>
</footer>
</body>
</html>
<script>
  const h=document.getElementById('hamburger'),o=document.getElementById('offcanvas'),v=document.getElementById('overlay'),c=document.getElementById('oc-close'),hd=document.getElementById('site-header');
  function open(){o?.classList.add('is-open');v?.classList.add('is-open');document.body.style.overflow='hidden';}
  function close(){o?.classList.remove('is-open');v?.classList.remove('is-open');document.body.style.overflow='';}
  h?.addEventListener('click',open);c?.addEventListener('click',close);v?.addEventListener('click',close);
  o?.querySelectorAll('.oc-links a').forEach(l=>l.addEventListener('click',close));
  window.addEventListener('scroll',()=>{hd?.classList.toggle('scrolled',window.scrollY>10);});
  if('serviceWorker' in navigator){navigator.serviceWorker.register('/sw.js');}
</script>
<style is:global>
:root{--c-primary:#16a34a;--c-primary-light:#22c55e;--c-primary-dark:#15803d;--c-primary-bg:#f0fdf4;--c-primary-100:#bbf7d0;--c-dark:#0f172a;--c-dark-2:#1e293b;--c-dark-3:#334155;--c-text:#0f172a;--c-text-2:#475569;--c-muted:#94a3b8;--c-bg:#fff;--c-bg-alt:#f8fafc;--c-border:#e2e8f0;--max-w:1140px;--r:12px;--r-sm:8px;--r-lg:16px;--shadow-sm:0 1px 3px rgba(15,23,42,.06);--shadow-md:0 4px 20px rgba(15,23,42,.08);--font-display:'Rubik',sans-serif;--font-body:'Rubik',sans-serif;--ease:cubic-bezier(.4,0,.2,1)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:var(--font-body);color:var(--c-text);background:var(--c-bg);line-height:1.7;font-size:16px;-webkit-font-smoothing:antialiased}
img{max-width:100%;height:auto;display:block}a{color:inherit}
h1,h2,h3,h4{font-family:var(--font-display);font-weight:700;line-height:1.2;letter-spacing:-.02em}
.site-header{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.95);backdrop-filter:blur(14px);border-bottom:1px solid transparent;transition:border-color .25s,box-shadow .25s}
.site-header.scrolled{border-bottom-color:var(--c-border);box-shadow:var(--shadow-sm)}
.header-inner{max-width:var(--max-w);margin:0 auto;padding:.6rem 2rem;display:flex;justify-content:space-between;align-items:center}
.logo{display:flex;align-items:center;gap:.55rem;text-decoration:none;font-family:var(--font-display);font-weight:800;font-size:1.1rem;color:var(--c-text)}
.logo-img{height:36px;width:auto}.logo-img-light{opacity:.9}
.nav-desktop{display:flex;align-items:center;gap:.15rem}
.nav-desktop a{text-decoration:none;font-family:var(--font-display);font-weight:500;font-size:.9rem;color:var(--c-text-2);padding:.45rem .9rem;border-radius:var(--r-sm);transition:color .2s,background .2s}
.nav-desktop a:hover,.nav-desktop a.active{color:var(--c-primary);background:var(--c-primary-bg)}
.nav-desktop a.nav-cta{background:var(--c-primary);color:#fff;margin-left:.4rem;padding:.45rem 1.1rem;font-weight:600}
.nav-desktop a.nav-cta:hover{background:var(--c-primary-dark);color:#fff}
.lang-switch{display:flex;gap:2px;margin-left:.5rem;background:var(--c-bg-alt);border-radius:6px;padding:2px;border:1px solid var(--c-border)}
.lang-switch a{text-decoration:none;font-family:var(--font-display);font-weight:600;font-size:.75rem;padding:.25rem .5rem;border-radius:4px;color:var(--c-muted);transition:all .2s}
.lang-switch a.active{background:var(--c-dark);color:#fff}
.lang-switch a:hover:not(.active){color:var(--c-text)}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:.5rem}
.hamburger span{display:block;width:22px;height:2px;background:var(--c-text);border-radius:2px}
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;opacity:0;pointer-events:none;transition:opacity .3s}
.overlay.is-open{opacity:1;pointer-events:auto}
.offcanvas{position:fixed;top:0;right:-320px;width:300px;height:100vh;background:#fff;z-index:201;display:flex;flex-direction:column;transition:right .35s var(--ease);box-shadow:-8px 0 30px rgba(0,0,0,.12)}
.offcanvas.is-open{right:0}
.oc-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.5rem;border-bottom:1px solid var(--c-border)}
.oc-header .logo-img{height:30px}
.oc-close{background:none;border:none;cursor:pointer;padding:.3rem;color:var(--c-text);border-radius:var(--r-sm)}
.oc-links{flex:1;padding:1rem 0;overflow-y:auto}
.oc-links a{display:block;text-decoration:none;font-family:var(--font-display);font-weight:500;font-size:1.05rem;color:var(--c-text-2);padding:.85rem 1.5rem;transition:background .2s,color .2s}
.oc-links a:hover,.oc-links a.active{background:var(--c-primary-bg);color:var(--c-primary)}
.oc-footer{padding:1.25rem 1.5rem;border-top:1px solid var(--c-border);background:var(--c-bg-alt)}
.oc-phone{display:inline-flex;align-items:center;gap:.4rem;text-decoration:none;font-family:var(--font-display);font-weight:700;font-size:.95rem;color:var(--c-primary)}
.oc-hours{font-size:.78rem;color:var(--c-muted);margin-top:.3rem}
@media(max-width:768px){.nav-desktop{display:none}.hamburger{display:flex}.header-inner{padding:.6rem 1.25rem}}
main{max-width:var(--max-w);margin:0 auto;padding:0 2rem;min-height:60vh}
@media(max-width:768px){main{padding:0 1.25rem}}
.site-footer{background:var(--c-dark);color:#94a3b8;margin-top:5rem}
.footer-inner{max-width:var(--max-w);margin:0 auto;padding:3.5rem 2rem 2.5rem;display:grid;grid-template-columns:1.8fr 1fr 1fr 1.4fr;gap:2.5rem}
.footer-brand .logo{color:#fff;margin-bottom:.75rem}.footer-tagline{font-size:.82rem;line-height:1.6;color:#64748b;max-width:300px}
.footer-links{display:flex;flex-direction:column;gap:.4rem}
.footer-links h4,.footer-contact h4{font-family:var(--font-display);font-size:.78rem;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#fff;margin-bottom:.3rem}
.footer-links a{text-decoration:none;font-size:.82rem;color:#64748b;transition:color .2s}.footer-links a:hover{color:#fff}
.footer-contact{display:flex;flex-direction:column;gap:.5rem}
.fc-item{display:flex;align-items:center;gap:.5rem;font-size:.82rem}
.fc-item a,.fc-item span{text-decoration:none;color:#64748b;transition:color .2s}.fc-item a:hover{color:#fff}
.fc-hours{font-size:.75rem;color:#64748b;margin-top:.25rem}
.footer-bottom{max-width:var(--max-w);margin:0 auto;padding:1.25rem 2rem;border-top:1px solid rgba(255,255,255,.06);text-align:center}
.footer-bottom p{font-size:.72rem;color:#475569}.footer-bottom a{color:#64748b;text-decoration:none}.footer-bottom a:hover{color:var(--c-primary)}
@media(max-width:768px){.footer-inner{grid-template-columns:1fr;gap:1.75rem;padding:2.5rem 1.25rem 2rem}}
.page-hero{background:#0f172a;width:100vw;margin-left:calc(-50vw + 50%);padding:4rem 2rem 3.5rem;margin-bottom:3rem;margin-top:-.5rem;overflow:hidden}
.page-hero-inner{max-width:var(--max-w);margin:0 auto;padding:0 2rem}
.page-hero .hero-label{display:inline-block;font-family:var(--font-display);font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:.12em;color:#22c55e;margin-bottom:.75rem}
.page-hero h1{font-size:clamp(1.75rem,3.5vw,2.5rem);line-height:1.15;color:#fff;margin-bottom:.75rem}
.page-hero .hero-accent{color:#22c55e}
.page-hero .hero-desc{font-size:1.05rem;color:#94a3b8;line-height:1.7;max-width:560px}
.page-hero .hero-meta{display:flex;align-items:center;gap:.75rem;margin-bottom:1rem}
.page-hero .hero-date{font-size:.82rem;color:#64748b}
.page-hero .hero-cat{font-size:.65rem;font-weight:600;text-transform:uppercase;color:#22c55e;background:rgba(34,197,94,.1);padding:.15rem .5rem;border-radius:4px}
@media(max-width:768px){.page-hero{padding:3rem 1.25rem 2.5rem}.page-hero-inner{padding:0}}
.btn{display:inline-flex;align-items:center;gap:.45rem;font-family:var(--font-display);font-weight:600;font-size:.9rem;padding:.7rem 1.4rem;border-radius:var(--r-sm);text-decoration:none;transition:all .25s;cursor:pointer;border:2px solid transparent}
.btn-primary{background:var(--c-primary);color:#fff;border-color:var(--c-primary)}.btn-primary:hover{background:var(--c-primary-dark);border-color:var(--c-primary-dark);transform:translateY(-1px);box-shadow:var(--shadow-md)}
.btn-dark{background:var(--c-dark);color:#fff;border-color:var(--c-dark)}
.btn-outline{background:transparent;color:var(--c-text);border-color:var(--c-border)}.btn-outline:hover{border-color:var(--c-primary);color:var(--c-primary)}
.btn-white{background:#fff;color:var(--c-dark);border-color:#fff}.btn-white:hover{background:var(--c-primary-bg);color:var(--c-primary)}
.fade-up{opacity:0;transform:translateY(16px);animation:fadeUp .5s ease forwards}
@keyframes fadeUp{to{opacity:1;transform:translateY(0)}}
</style>
